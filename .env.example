# ---------------------------------------------------------------------------
# Tessera environment configuration. Copy to `.env` and fill in.
# `.env` is gitignored; only this example is committed. No real secrets here.
# ---------------------------------------------------------------------------

# Deployment profile: "local" (DuckDB + SQLite Iceberg catalog + filesystem)
# or "cloud" (Snowflake/Athena + Glue catalog + S3).
PROFILE=local

# REQUIRED by SEC EDGAR: a descriptive User-Agent of the form "Name email@example.com".
# Requests without one may be throttled or blocked.
SEC_USER_AGENT=Your Name your.email@example.com

# Self-imposed request cap (requests/second). SEC asks for <= 10.
REQUEST_RATE_LIMIT=10

# --- Local storage / warehouse -------------------------------------------------
# Root directory for landed data, warehouse files, and the Iceberg catalog.
DATA_DIR=./data
DUCKDB_PATH=./data/tessera.duckdb
ICEBERG_CATALOG_URI=sqlite:///./data/iceberg_catalog.db
ICEBERG_WAREHOUSE=./data/iceberg_warehouse

# --- Object storage (MinIO local / S3 cloud) ----------------------------------
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=tessera
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# --- Cloud warehouse (only used when PROFILE=cloud) ----------------------------
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_DATABASE=TESSERA
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_SCHEMA=PUBLIC

# --- Optional integrations -----------------------------------------------------
# Optional price feed for valuation ratios (kept behind the PriceProvider interface).
PRICE_PROVIDER_API_KEY=
# Optional, for the stretch RAG-over-filings layer.
ANTHROPIC_API_KEY=
